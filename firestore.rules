rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: Check if user is admin ───────────────
    function isAdminUser() {
      return request.auth != null
        && exists(/databases/$(database)/documents/appConfig/settings)
        && request.auth.token.email in get(/databases/$(database)/documents/appConfig/settings).data.adminEmails;
    }

    // ─── App Config (feature settings, admin emails) ──
    match /appConfig/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Users collection ─────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Legacy connections subcollection
      match /connections/{connectionId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ─── User settings ────────────────────────────────
    match /userSettings/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Banned users ─────────────────────────────────
    match /bannedUsers/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Disabled users ───────────────────────────────
    match /disabledUsers/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Top-level connections collection ──────────────
    match /connections/{connectionId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.users;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.users
        && request.resource.data.users.size() == 2;
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.users;
    }

    // ─── Posts (feed) ─────────────────────────────────
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Any authenticated user can update (needed for reactions)
      allow update: if request.auth != null;
      // Only the post author can delete
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.userId);

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        // Comment author can update (e.g. remove image) or delete their own comment
        allow update: if request.auth != null
          && request.auth.uid == resource.data.userId;
        allow delete: if request.auth != null
          && (request.auth.uid == resource.data.userId || request.auth.uid == get(/databases/$(database)/documents/posts/$(postId)).data.authorId || request.auth.uid == get(/databases/$(database)/documents/posts/$(postId)).data.userId);
      }

      match /likes/{likeId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == likeId;
      }
    }

    // ─── Business listings ────────────────────────────
    match /businesses/{businessId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ─── Business Menu Items ────────────────────────
    match /businessMenuItems/{itemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ─── Business Reviews ───────────────────────────
    match /businessReviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ─── Business Orders ────────────────────────────
    match /businessOrders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ─── Events ───────────────────────────────────────
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Any authenticated user can update (needed for RSVP, waitlist)
      allow update: if request.auth != null;
      // Only the event poster can delete
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.posterId || request.auth.uid == resource.data.createdBy || request.auth.uid == resource.data.userId);

      // Event comments / discussion thread
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null
          && request.auth.uid == resource.data.userId;
      }
    }

    // ─── Housing listings (collection name: "listings") ─
    match /listings/{listingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.posterId || request.auth.uid == resource.data.userId);

      // ─── Housing listing comments ─────────────────────
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.userId;
      }
    }

    // ─── Legacy housing path ──────────────────────────
    match /housing/{listingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ─── Forum threads ────────────────────────────────
    match /forumThreads/{threadId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Any auth user can update (needed for voting, accepted reply)
      allow update: if request.auth != null;
      // Only the thread author can delete
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;

      // Subcollection replies
      match /replies/{replyId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
      }

      // Subcollection likes/votes
      match /likes/{likeId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
      match /forumLikes/{voteId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }

    // ─── Forum replies (top-level collection) ─────────
    match /forumReplies/{replyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Any auth user can update (needed for voting, accepted status)
      allow update: if request.auth != null;
      // Only the reply author can delete
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;

      // Subcollection votes
      match /forumLikes/{voteId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }

    // ─── Forum likes (top-level collection) ───────────
    match /forumLikes/{likeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Messages / Conversations ─────────────────────
    match /conversations/{conversationId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow delete: if request.auth != null;

      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null;
      }
    }

    // ─── Travel posts ─────────────────────────────────
    match /travelPosts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (request.auth.uid == resource.data.posterId || request.auth.uid == resource.data.userId);
    }

    // ─── Legacy travel path ───────────────────────────
    match /travelListings/{listingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ─── Marketplace listings ─────────────────────────
    match /marketplaceListings/{listingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.sellerId;
    }

    // ─── Marketplace comments ───────────────────────
    match /marketplaceComments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    // ─── Announcements ────────────────────────────────
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Moderation queue ─────────────────────────────
    match /moderationQueue/{itemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ─── Reports ──────────────────────────────────────
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // ─── Admin settings (legacy) ──────────────────────
    match /adminSettings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
